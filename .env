# Root folder structure: FILE_ROOT_PATH/<segment>/<date>/<files>
FILE_ROOT_PATH=C:/Users/Deviprasad Gurrana/mofsl/edpb
DATE_FOLDER_FORMAT=%d-%m-%Y

# Scheduler
POLL_INTERVAL_MINUTES=1
# How many days in the past to scan (1 = Today and Yesterday. 2 = Today, Yesterday and 2 days ago, etc.)
SCAN_DAYS_BACK=1

# CBOS trade-upload API 
# MOCK -> no network calls, canned responses (see MockCBOSClient). Safe default.
# REAL -> calls the actual CBOS host at CBOS_BASE_URL.

# CBOS_BASE_URL is the shared host for all 5 endpoints, e.g.:
#   https://cbos-host/api/getNewTradeProcess
#   https://cbos-host/api/GetNewTradeProcessPromodalUploadSettings
#   https://cbos-host/api/SaveTradePromodalUploadChunkFile
#   https://cbos-host/api/SaveNewTradeProcessPromodalUploadFile
#   https://cbos-host/api/file_process_status
# Only used when CBOS_MODE=REAL.
CBOS_BASE_URL= http://10.167.202.234:8087
CBOS_LOGIN_ID=CV0001
CBOS_PASSWORD="Master#123"
CBOS_TIMEOUT_SECONDS=30
CBOS_POLL_INTERVAL_SECONDS=2
CBOS_POLL_MAX_ATTEMPTS=30

# MockCBOSClient tuning - only used when CBOS_MODE=MOCK.
CBOS_MOCK_RANDOM_SUCCESS_RATE=0.7
CBOS_MOCK_PENDING_POLLS=2

LOG_LEVEL=DEBUG
CBOS_MODE=MOCK

# PostgreSQL
DATABASE_URL=postgresql://postgres:Deviprasad%402002@localhost:5432/edp_cbos

# BSE member extranet portal - used only by scripts/bse_downloader.py
# (a standalone Playwright script, not the FastAPI app). Rotate this
# password on the BSE portal since it was shared in plain text in chat.
BSE_MEMBER_CODE=0446
BSE_USER_ID=0446
BSE_PASSWORD=Mosl@5555
