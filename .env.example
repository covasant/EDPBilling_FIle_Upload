# Root folder structure: FILE_ROOT_PATH/<segment>/<date>/<files>
FILE_ROOT_PATH=<path-to-root-folder>
DATE_FOLDER_FORMAT=%d-%m-%Y

# Scheduler
POLL_INTERVAL_SECONDS=30
# How many days in the past to scan (1 = Today and Yesterday. 2 = Today, Yesterday and 2 days ago, etc.)
SCAN_DAYS_BACK=1

# CBOS trade-upload API
# MOCK -> no network calls, canned responses (see MockCBOSClient). Safe default.
# REAL -> calls the actual CBOS hosts below.

# Per EDP_Trade_Process_API_Documentation_v4.pdf, the GTG/CHK calls
# (file_process_status, get_expected_filename) and the CORE process/
# brokerage calls (getNewTradeProcess, upload settings, chunk upload, file
# entry) live on two DIFFERENT hosts. REQUIRED when CBOS_MODE=REAL - there are
# no committed defaults, so REAL mode fails fast if any of the four are unset.
# Never commit real values here; keep them in .env only.
CBOS_GTG_BASE_URL=http://<gtg-host>:<port>
CBOS_CORE_BASE_URL=http://<core-host>:<port>
CBOS_LOGIN_ID=<your-login-id>
CBOS_PASSWORD=<your-password>
CBOS_TIMEOUT_SECONDS=30
CBOS_UPLOAD_TIMEOUT_SECONDS=300
CBOS_POLL_INTERVAL_SECONDS=2
CBOS_POLL_MAX_ATTEMPTS=30

# Step 7's "ipaddress" field. The API doc's example fills it with the CORE
# host's own address, not the caller's - so it may say where the uploaded file
# lives rather than who sent it. Leave empty to send this machine's IP (the
# original behaviour); set it once the CBOS team confirms which they expect.
CBOS_UPLOAD_IP_ADDRESS=
# Bounded retry for per-batch setup (reserve PROCESSID + fetch upload rules).
CBOS_MAX_RETRIES=2
CBOS_RETRY_DELAY_SECONDS=2

# File-to-UploadID matching (app/services/upload_matching.py). Column-count
# validation only applies to delimited text files (csv/txt) - it's skipped,
# not failed, for binary formats like .xlsx.
UPLOAD_MATCH_VALIDATE_COLUMNS=true
UPLOAD_MATCH_DELIMITER=,

# Step 4 file chunking - files are streamed and uploaded in CHUNK_SIZE_KB
# pieces instead of loading the whole file into memory. A file smaller than
# CHUNK_SIZE_KB still uploads as a single CurrentChunk=1/TotalChunks=1 call.
# Use a small value (e.g. 512) to test multi-chunk uploads with small files;
# use a large value (e.g. 51200 = 50 MB, or 1048576 = 1 GB) for production.
CHUNK_SIZE_KB=512
CBOS_CHUNK_RETRY_ATTEMPTS=3

# MockCBOSClient tuning - only used when CBOS_MODE=MOCK.
CBOS_MOCK_RANDOM_SUCCESS_RATE=0.7
CBOS_MOCK_PENDING_POLLS=2

LOG_LEVEL=INFO
CBOS_MODE=REAL

# PostgreSQL
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<db-name>

# BSE member extranet portal - used only by scripts/bse_downloader.py
# (a standalone Playwright script, not the FastAPI app).
BSE_MEMBER_CODE=
BSE_USER_ID=
BSE_PASSWORD=
