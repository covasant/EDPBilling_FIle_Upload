# Root folder structure: FILE_ROOT_PATH/<segment>/<date>/<files>
# Completeness-gate allowlist (code-reviewed YAML; see BATCH_HANDOFF_CONTRACT.md)
# OPTIONAL_SLOTS_PATH=app/config/optional_slots.yaml
FILE_ROOT_PATH=<path-to-root-folder>
DATE_FOLDER_FORMAT=%d-%m-%Y

# Scheduler
# How many days in the past to scan (1 = Today and Yesterday. 2 = Today, Yesterday and 2 days ago, etc.)

# CBOS trade-upload API
# MOCK -> no network calls, canned responses (see MockCBOSClient). Safe default.
# REAL -> calls the actual CBOS hosts below.

# Per EDP_Trade_Process_API_Documentation_v4.pdf, the GTG/CHK calls
# (file_process_status, get_expected_filename) and the CORE process/
# brokerage calls (getNewTradeProcess, upload settings, chunk upload, file
# entry) live on two DIFFERENT hosts. REQUIRED when CBOS_MODE=REAL - there are
# no committed defaults, so REAL mode fails fast if any of the four are unset.
# Never commit real values here; keep them in .env only.
CBOS_GTG_BASE_URL=http://<gtg-host>:<port>
CBOS_CORE_BASE_URL=http://<core-host>:<port>
CBOS_LOGIN_ID=<your-login-id>
CBOS_PASSWORD=<your-password>
CBOS_TIMEOUT_SECONDS=30
CBOS_UPLOAD_TIMEOUT_SECONDS=300
CBOS_POLL_INTERVAL_SECONDS=2
CBOS_POLL_MAX_ATTEMPTS=30

# Step 7's "ipaddress" field. Not the caller's address - CBOS expects the CORE
# host's own IP, matching the API doc's example. Leave empty only to fall back
# to this machine's IP (the original, incorrect behaviour).
CBOS_UPLOAD_IP_ADDRESS=<core-host-ip>
# Bounded retry for per-batch setup (reserve PROCESSID + fetch upload rules).
CBOS_MAX_RETRIES=2
CBOS_RETRY_DELAY_SECONDS=2

# File-to-UploadID matching (app/services/upload_matching.py). Column-count
# validation only applies to delimited text files (csv/txt) - it's skipped,
# not failed, for binary formats like .xlsx.
UPLOAD_MATCH_VALIDATE_COLUMNS=true
UPLOAD_MATCH_DELIMITER=,

# Step 4 file chunking - files are streamed and uploaded in CHUNK_SIZE_KB
# pieces instead of loading the whole file into memory. A file smaller than
# CHUNK_SIZE_KB still uploads as a single CurrentChunk=1/TotalChunks=1 call.
# Use a small value (e.g. 512) to test multi-chunk uploads with small files;
# use a large value (e.g. 51200 = 50 MB, or 1048576 = 1 GB) for production.
CHUNK_SIZE_KB=512
CBOS_CHUNK_RETRY_ATTEMPTS=3

# MockCBOSClient tuning - only used when CBOS_MODE=MOCK.
CBOS_MOCK_RANDOM_SUCCESS_RATE=0.7
CBOS_MOCK_PENDING_POLLS=2
# Make Step 1 answer "holiday" so the skip-the-batch branch can be exercised.
CBOS_MOCK_HOLIDAY=false

# Step 1 (BeginFileUpload) holiday check. false = observe only: the check runs
# and its answer is logged, but never stops a batch. Enforcing turns on "any
# message except SKIP means holiday" - a rule from the API doc that no real CBOS
# reply has confirmed yet, so enforcing it early could halt every upload while
# looking like a quiet day. Set true once the real response is confirmed.
CBOS_HOLIDAY_CHECK_ENFORCED=false

LOG_LEVEL=INFO
CBOS_MODE=REAL

# PostgreSQL
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<db-name>

# BSE member extranet portal - used only by scripts/bse_downloader.py
# (a standalone Playwright script, not the FastAPI app).
BSE_MEMBER_CODE=
BSE_USER_ID=
BSE_PASSWORD=

# ---------------------------------------------------------------------------
# Settlement segment - DP File Upload API (separate upstream from CBOS above,
# same FastAPI app/.env). See DP_FileUpload_API_Integration_Guide.docx.
# MOCK -> no network calls, canned responses (see MockDPUploadClient).
# REAL -> calls the actual DP upload host below.
# ---------------------------------------------------------------------------
CBOS_SETL_MODE=MOCK

# Where the settlement file-download bot drops files. The orchestrator calls
# POST /settlements/uploads with just {upload_id, file_name} - this service
# looks the file up here by name rather than receiving bytes.
CBOS_SETL_SHARED_FOLDER_PATH=<path-to-shared-settlement-folder>

# Base URL/prefix conflict between the two source docs is UNRESOLVED - leave
# blank until confirmed with the CAMS/DP team, do not guess:
#   integration guide: http://<host>:44300  + /api/dp/upload/
#   actual-requests:   http://10.167.202.164:8002 + mixed /api|/v1/api prefix
CBOS_SETL_BASE_URL=<host-and-port-tbd>
CBOS_SETL_API_PREFIX=<prefix-tbd>

# Session-Value header: "<seskey>|<user_id>" on every DP upload call.
# Static config for now - whether seskey needs its own login/refresh call is
# unconfirmed.
CBOS_SETL_SESKEY=<seskey>
CBOS_SETL_USER_ID=<user-id>
CBOS_SETL_CREATED_BY=<created-by-user-id>

CBOS_SETL_TIMEOUT_SECONDS=30
CBOS_SETL_UPLOAD_TIMEOUT_SECONDS=300
CBOS_SETL_POLL_INTERVAL_SECONDS=5
CBOS_SETL_POLL_MAX_ATTEMPTS=60
CBOS_SETL_MAX_RETRIES=2
CBOS_SETL_RETRY_DELAY_SECONDS=2

# uploadchunks (Step 4): doc specifies a hard 5MB/chunk, 512MB total limit.
CHUNK_SETL_SIZE_KB=5120

# MockDPUploadClient tuning - only used when CBOS_SETL_MODE=MOCK.
CBOS_SETL_MOCK_RANDOM_SUCCESS_RATE=0.9
CBOS_SETL_MOCK_PENDING_POLLS=2
