    "/v1/api/process/MTFTradeProcessFundTransfer": {
      "post": {
        "summary": "Step 24: Fund Transfer - Trigger",
        "description": "Triggers MTF Fund Transfer. Requires the SQL Server Agent job 'MTF_RISK_UPDATE' to exist on the target server — otherwise returns an error indicating the job does not exist.",
        "operationId": "triggerFundTransfer",
        "tags": ["Collateral & Fund Transfer"],
        "servers": [{ "url": "http://10.167.202.164:8003" }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MTFDateRequest" } } }
        },
        "responses": {
          "200": {
            "description": "Fund transfer result (or SQL job-not-found error)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "Status": { "type": "string", "example": "Success" },
                    "Result": {
                      "type": "array",
                      "items": { "type": "object", "properties": { "Result": { "type": "string", "example": "The specified @job_name ('MTF_RISK_UPDATE') does not exist." } } }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
