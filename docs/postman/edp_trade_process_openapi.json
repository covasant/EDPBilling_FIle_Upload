    "/v1/api/process/GetCollateralValuation": {
      "post": {
        "summary": "Collateral Valuation - Check Status / Trigger (Steps 17-18)",
        "description": "BUTTONNAME=REFRESH polls whether a valuation run is in progress (Step 17; empty Table1 = not yet triggered). BUTTONNAME=COLLATERAL_VALUATION_DATEWISE triggers date-wise Collateral Valuation (Step 18). This starts the process asynchronously — re-check the GTG endpoint until MSG=TRUE.",
        "operationId": "getCollateralValuation",
        "tags": ["Collateral & Fund Transfer"],
        "servers": [{ "url": "http://10.167.202.164:8003" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CollateralValuationRequest" },
              "examples": {
                "Step17_Refresh": { "summary": "Step 17: Check Status (Refresh)", "value": { "BUTTONNAME": "REFRESH", "LOGINID": "CV0001" } },
                "Step18_Trigger": { "summary": "Step 18: Trigger date-wise valuation", "value": { "BUTTONNAME": "COLLATERAL_VALUATION_DATEWISE", "LOGINID": "CV0001", "MARGINDATE": "19-Jun-2026" } }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Table1 empty = not yet triggered; populated = process started/running",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TableResultResponse" } } }
          }
        }
      }
    },
