    "/v1/api/process/SaveTradePromodalUploadChunkFile": {
      "post": {
        "summary": "Step 5: File Upload - Chunk API",
        "description": "Upload the file in chunks. For files > 1 MB, call this multiple times incrementing CurrentChunk from 0 to TotalChunks-1. A new GUID must be generated per upload.",
        "operationId": "saveTradeUploadChunkFile",
        "tags": ["Core Trade Process"],
        "servers": [{ "url": "http://10.167.202.164:8003" }],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["file", "CurrentChunk", "TotalChunks", "Guid", "FileName"],
                "properties": {
                  "file": { "type": "string", "format": "binary" },
                  "CurrentChunk": { "type": "integer", "example": 0 },
                  "TotalChunks": { "type": "integer", "example": 1 },
                  "Guid": { "type": "string", "format": "uuid", "description": "New GUID per upload", "example": "a1b2c3d4-e5f6-4789-abcd-ef0123456789" },
                  "FileName": { "type": "string", "example": "SCRIP_190626.TXT" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Chunk upload acknowledgement. Save the returned Guid — it is used as uploadfoldername in Step 7.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ChunkUploadResponse" } } }
          }
        }
      }
    },
