          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/MTFTradeProcessRequest" },
              "examples": {
                "Step26_MTFBuyProcess": { "summary": "Step 26: MTF Buy Trade Process", "value": { "LOGINID": "CV0001", "TRADEDATE": "30-JUN-2026", "TYPE": "BUY PROCESS" } },
                "Step27_MTFBuyPosting": { "summary": "Step 27: MTF Buy Trade Posting", "value": { "LOGINID": "CV0001", "TRADEDATE": "30-JUN-2026", "TYPE": "BUY POSTING" } },
                "Step29_MTFSellProcessAndPosting": { "summary": "Step 29: MTF Sell Process & Posting", "value": { "LOGINID": "CV0001", "TRADEDATE": "30-JUN-2026", "TYPE": "SELL PROCESS AND POSTING" } },
                "Step32_WeeklyAutoClosure": { "summary": "Step 32: Weekly Auto Closure Run", "value": { "LOGINID": "CV0001", "TRADEDATE": "30-JUN-2026", "TYPE": "WEEKLY AUTOCLOSURE" } }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Process completion result",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MTFTradeProcessResponse" } } }
          }
        }
      }
    },
